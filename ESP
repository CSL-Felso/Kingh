-- [[ MOTOR SISTEMA DE ESP (DRAWING & HIGHLIGHTS) ]]
-- ====================================================================

local cache = {}

local function criarEstruturaESP(plr)
    if cache[plr] then return end

    local estruturas = {
        Box = Drawing.new("Square"),
        Name = Drawing.new("Text"),
        Tracer = Drawing.new("Line"),
        Skeleton = {},
        Highlight = Instance.new("Highlight")
    }

    estruturas.Box.Thickness = 1.5
    estruturas.Box.Filled = false
    estruturas.Box.Color = ESPConfig.CorGeral

    estruturas.Name.Size = 14
    estruturas.Name.Center = true
    estruturas.Name.Outline = true
    estruturas.Name.Color = Color3.new(1, 1, 1)

    estruturas.Tracer.Thickness = 1
    estruturas.Tracer.Color = ESPConfig.CorGeral

    for i = 1, 10 do
        local l = Drawing.new("Line")
        l.Thickness = 1.5
        l.Color = ESPConfig.CorGeral
        table.insert(estruturas.Skeleton, l)
    end

    estruturas.Highlight.FillColor = ESPConfig.CorAura
    estruturas.Highlight.FillTransparency = 0.5
    estruturas.Highlight.OutlineColor = Color3.new(1, 1, 1)
    estruturas.Highlight.OutlineTransparency = 0

    cache[plr] = estruturas
end

local function limparESP(plr)
    if cache[plr] then
        cache[plr].Box:Remove()
        cache[plr].Name:Remove()
        cache[plr].Tracer:Remove()
        for _, linha in pairs(cache[plr].Skeleton) do linha:Remove() end
        if cache[plr].Highlight then cache[plr].Highlight:Destroy() end
        cache[plr] = nil
    end
end

Players.PlayerAdded:Connect(criarEstruturaESP)
Players.PlayerRemoving:Connect(limparESP)
for _, p in pairs(Players:GetPlayers()) do if p ~= LocalPlayer then criarEstruturaESP(p) end end

-- [[ LOOP DE RENDERIZAÇÃO EM TEMPO REAL ]]
RunService.RenderStepped:Connect(function()
    for plr, esp in pairs(cache) do
        local char = plr.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        local head = char and char:FindFirstChild("Head")

        -- LINHA CORRIGIDA AQUI:
        if hrp and hum and head and hum.Health > 0 then
            local hrpPos, naTela = Camera:WorldToViewportPoint(hrp.Position)

            -- 1. ESP QUADRADO & NOME
            if naTela and (ESPConfig.Quadrado or ESPConfig.Nome) then
                local headPos = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 2, 0))
                local legPos = Camera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3, 0))
                
                local boxHeight = math.abs(headPos.Y - legPos.Y)
                local boxWidth = boxHeight * 0.6

                if ESPConfig.Quadrado then
                    esp.Box.Size = Vector2.new(boxWidth, boxHeight)
                    esp.Box.Position = Vector2.new(hrpPos.X - boxWidth / 2, hrpPos.Y - boxHeight / 2)
                    esp.Box.Visible = true
                else esp.Box.Visible = false end

                if ESPConfig.Nome then
                    esp.Name.Text = plr.Name .. " [" .. math.floor(hum.Health) .. " HP]"
                    esp.Name.Position = Vector2.new(hrpPos.X, (hrpPos.Y - boxHeight / 2) - 16)
                    esp.Name.Visible = true
                else esp.Name.Visible = false end
            else
                esp.Box.Visible = false
                esp.Name.Visible = false
            end

            -- 2. ESP LINHAS (TRACERS)
            if naTela and ESPConfig.Linhas then
                esp.Tracer.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                esp.Tracer.To = Vector2.new(hrpPos.X, hrpPos.Y)
                esp.Tracer.Visible = true
            else
                esp.Tracer.Visible = false
            end

            -- 3. ESP AURA (HIGHLIGHTS)
            if ESPConfig.Aura then
                if esp.Highlight.Parent ~= char then
                    esp.Highlight.Parent = char
                end
                esp.Highlight.Enabled = true
            else
                esp.Highlight.Enabled = false
            end

            -- 4. ESP ESQUELETO (R6 e R15)
            if naTela and ESPConfig.Esqueleto then
                local juntas = {}
                local n = 1

                local partesR15 = {"Head", "UpperTorso", "LowerTorso", "LeftUpperArm", "LeftLowerArm", "RightUpperArm", "RightLowerArm", "LeftUpperLeg", "LeftLowerLeg", "RightUpperLeg", "RightLowerLeg"}
                local usarPartes = char:FindFirstChild("UpperTorso") and partesR15 or {"Head", "Torso", "Left Arm", "Right Arm", "Left Leg", "Right Leg"}

                for _, nomePart in pairs(usarPartes) do
                    local p = char:FindFirstChild(nomePart)
                    if p then
                        local vPos, vOn = Camera:WorldToViewportPoint(p.Position)
                        juntas[nomePart] = {Pos = Vector2.new(vPos.X, vPos.Y), On = vOn}
                    end
                end

                local function conectar(p1, p2)
                    local j1, j2 = juntas[p1], juntas[p2]
                    if j1 and j2 and j1.On and j2.On and esp.Skeleton[n] then
                        esp.Skeleton[n].From = j1.Pos
                        esp.Skeleton[n].To = j2.Pos
                        esp.Skeleton[n].Visible = true
                        n = n + 1
                    end
                end

                if char:FindFirstChild("UpperTorso") then
                    conectar("Head", "UpperTorso")
                    conectar("UpperTorso", "LowerTorso")
                    conectar("UpperTorso", "LeftUpperArm")
                    conectar("LeftUpperArm", "LeftLowerArm")
                    conectar("UpperTorso", "RightUpperArm")
                    conectar("RightUpperArm", "RightLowerArm")
                    conectar("LowerTorso", "LeftUpperLeg")
                    conectar("LeftUpperLeg", "LeftLowerLeg")
                    conectar("LowerTorso", "RightUpperLeg")
                    conectar("RightUpperLeg", "RightLowerLeg")
                else
                    conectar("Head", "Torso")
                    conectar("Torso", "Left Arm")
                    conectar("Torso", "Right Arm")
                    conectar("Torso", "Left Leg")
                    conectar("Torso", "Right Leg")
                end

                for i = n, #esp.Skeleton do esp.Skeleton[i].Visible = false end
            else
                for _, linha in pairs(esp.Skeleton) do linha.Visible = false end
            end

        else
            esp.Box.Visible = false
            esp.Name.Visible = false
            esp.Tracer.Visible = false
            esp.Highlight.Enabled = false
            for _, linha in pairs(esp.Skeleton) do linha.Visible = false end
        end
    end
end)
