-- [[ FUNÇÃO PARA ANIMAR TOGGLE ]]
local function animarToggle(toggle, knob, status, on)
    if on then
        TweenService:Create(toggle, TweenInfo.new(.2), {BackgroundColor3 = Color3.fromRGB(76, 255, 76)}):Play()
        TweenService:Create(knob, TweenInfo.new(.2), {Position = UDim2.new(1, -21, .5, -9)}):Play()  
        status.Text = "ON"  
        status.TextColor3 = Color3.fromRGB(0, 255, 0)  
    else  
        TweenService:Create(toggle, TweenInfo.new(.2), {BackgroundColor3 = Color3.fromRGB(90, 90, 90)}):Play()  
        TweenService:Create(knob, TweenInfo.new(.2), {Position = UDim2.new(0, 3, .5, -9)}):Play()  
        status.Text = "OFF"  
        status.TextColor3 = Color3.fromRGB(255, 80, 80)  
    end
end

