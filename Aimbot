-- [[ LÓGICA DO ALVO MAIS PRÓXIMO ]]
local function pegarJogadorMaisProximo()
    local maiorDistancia = AimbotConfig.FOV
    local jogadorAlvo = nil
    local mousePos = UIS:GetMouseLocation()

    for _, jogador in pairs(Players:GetPlayers()) do
        if jogador ~= LocalPlayer and jogador.Character then
            local caractere = jogador.Character
            local parteCorpo = caractere:FindFirstChild(AimbotConfig.AlvoParte)
            local humanoide = caractere:FindFirstChildOfClass("Humanoid")

            if parteCorpo and humanoide and humanoide.Health > 0 then
                local posicaoTela, naTela = Camera:WorldToViewportPoint(parteCorpo.Position)

                if naTela then
                    local distanciaDoMouse = (Vector2.new(posicaoTela.X, posicaoTela.Y) - mousePos).Magnitude
                    if distanciaDoMouse < maiorDistancia then
                        maiorDistancia = distanciaDoMouse
                        jogadorAlvo = parteCorpo
                    end
                end
            end
        end
    end
    return jogadorAlvo
end

-- [[ PROCESSAMENTO VISUAL DO FOV ]]
RunService.RenderStepped:Connect(function()
    if AimbotConfig.MostrarFOV then
        FOVCircle.Position = UIS:GetMouseLocation()
        FOVCircle.Radius = AimbotConfig.FOV
        FOVCircle.Visible = true
    else
        FOVCircle.Visible = false
    end
end)

-- [[ PIPELINE DO AIM ASSIST SIMULADO (CONSOLE LOGIC) ]]
RunService:BindToRenderStep("MagicAimbotPipeline", Enum.RenderPriority.Camera.Value + 1, function()
    -- Executa apenas se estiver ativo E clicando com o Botão Direito (MouseButton2) ou Esquerdo (MouseButton1)
    if AimbotConfig.Ativo and (UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) or UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton1)) then
        local alvo = pegarJogadorMaisProximo()
        if alvo then
            local mousePos = UIS:GetMouseLocation()
            local posicaoTela, naTela = Camera:WorldToViewportPoint(alvo.Position)
            
            if naTela then
                -- Distância real em pixels entre o crosshair e o osso do inimigo
                local distanciaDoMouse = (Vector2.new(posicaoTela.X, posicaoTela.Y) - mousePos).Magnitude
                
                -- Proximidade vai de 0.0 (exatamente no centro) até 1.0 (na borda limite do FOV)
                local proximidade = math.clamp(distanciaDoMouse / AimbotConfig.FOV, 0, 1)
                
                -- MATEMÁTICA DO AIM ASSIST (Desaceleração Dinâmica):
                -- Quanto maior a proximidade (mais longe do centro), menor o amortecimento -> Câmera corre rápido.
                -- Quanto menor a proximidade (perto do centro), maior o amortecimento -> Câmera ganha peso magnético.
                local alphaBase = 1 / AimbotConfig.Suavidade
                local fatorConsole = alphaBase * (0.2 + (proximidade * 0.8))
                
                -- Aplica a rotação pura da câmera via CFrame com o peso corrigido
                local direcaoAlvo = CFrame.new(Camera.CFrame.Position, alvo.Position)
                Camera.CFrame = Camera.CFrame:Lerp(direcaoAlvo, fatorConsole)
            end
        end
    end
end)

-- [[ CONTROLADORES DA JANELA ]]
local dragging, startPos, startMouse
top.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
        dragging = true; startMouse = i.Position; startPos = main.Position
    end
end)
UIS.InputChanged:Connect(function(i)
    if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
        local delta = i.Position - startMouse
        main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UIS.InputEnded:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then dragging = false end
end)

