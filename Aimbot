local function CriarToggle(texto, estadoInicial, callback)
    local holder = Instance.new("Frame")
    holder.Size = UDim2.new(1, -10, 0, 40)
    holder.BackgroundColor3 = Tema.FundoSecundario
    holder.BorderSizePixel = 0
    holder.Parent = scroll
    Instance.new("UICorner", holder).CornerRadius = UDim.new(0, 6)

    local txt = Instance.new("TextLabel")
    txt.BackgroundTransparency = 1
    txt.Size = UDim2.new(1, -70, 1, 0)
    txt.Position = UDim2.new(0, 12, 0, 0)
    txt.Font = Enum.Font.GothamSemibold
    txt.Text = texto
    txt.TextColor3 = Tema.Texto
    txt.TextSize = 13
    txt.TextXAlignment = Enum.TextXAlignment.Left
    txt.Parent = holder

    local btn = Instance.new("TextButton")
    btn.Size = UDim2.fromOffset(40, 20)
    btn.Position = UDim2.new(1, -52, 0.5, -10)
    btn.BackgroundColor3 = estadoInicial and Tema.ToggleOn or Tema.ToggleOff
    btn.Text = ""
    btn.AutoButtonColor = false
    btn.Parent = holder
    Instance.new("UICorner", btn).CornerRadius = UDim.new(1, 0)

    local knob = Instance.new("Frame")
    knob.Size = UDim2.fromOffset(16, 16)
    knob.Position = estadoInicial and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)
    knob.BackgroundColor3 = Color3.new(1, 1, 1)
    knob.Parent = btn
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    local estadoLocal = estadoInicial

    btn.MouseButton1Click:Connect(function()
        estadoLocal = not estadoLocal
        if estadoLocal then
            TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Tema.ToggleOn}):Play()
            TweenService:Create(knob, TweenInfo.new(0.2), {Position = UDim2.new(1, -18, 0.5, -8)}):Play()
        else
            TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Tema.ToggleOff}):Play()
            TweenService:Create(knob, TweenInfo.new(0.2), {Position = UDim2.new(0, 2, 0.5, -8)}):Play()
        end
        if callback then callback(estadoLocal) end
    end)
end

